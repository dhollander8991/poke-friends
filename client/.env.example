# Client build-time config (Vite). Copy to client/.env and fill in.

# Where the game server lives (Socket.IO + REST). Defaults to localhost:3001.
VITE_SERVER_URL=http://localhost:3001

# Optional — enables "Sign in with Google" in Settings.
# Create an OAuth 2.0 Client ID (type: Web) at https://console.cloud.google.com/apis/credentials
# and add your origin (e.g. http://localhost:5173) to Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=

# Optional — enables "Sign in with Facebook" in Settings.
# Create an app at https://developers.facebook.com/ and use its App ID.
VITE_FACEBOOK_APP_ID=
