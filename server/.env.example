# ── Server ─────────────────────────────────────────────────
PORT=3001                          # HTTP / Socket.IO port

# ── CORS ───────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173   # Allowed client origin

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=                        # REQUIRED in production — long random string (≥32 chars)
JWT_EXPIRY=7d                      # Token lifetime; supports ms/s/m/h/d suffixes

# ── Game settings ──────────────────────────────────────────
SMALL_BLIND=50                     # Small blind amount in chips
BIG_BLIND=100                      # Big blind amount in chips
STARTING_CHIPS=500                 # Free-tier chip stack for new players
ACTION_TIMEOUT_SECS=30             # Seconds before auto-fold on inaction
SHOWDOWN_DELAY_MS=5000             # Milliseconds to display showdown before next hand

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_test_... (test) or sk_live_... (production)
STRIPE_WEBHOOK_SECRET=             # whsec_... from Stripe dashboard webhook settings

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # sk-ant-... from console.anthropic.com
